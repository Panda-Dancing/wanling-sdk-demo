# 本地环境配置文件
# 以 VITE_ 开头的变量会被 Vite 暴露给客户端代码

# 后端 API 基础地址
# 开发时使用本地后端服务，通过 Vite 代理转发
# 如果后端服务在其他地址，请修改此处
VITE_API_BASE_URL=http://localhost:8000/

# 使用本地 SDK 源码（调试模式）
# 启用后会将 @wanlingsdk/avatar-sdk 指向 ../SDK-video/src
VITE_USE_LOCAL_SDK=true

# 注意：
# 1. 修改此文件后需要重启开发服务器才能生效
# 2. 生产环境配置请创建 .env.production 文件
